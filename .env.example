# Database
DATABASE_URL="postgresql://musuhi_user:musuhi_password@db:5432/musuhi_db?schema=public"
DIRECT_URL="postgresql://musuhi_user:musuhi_password@db:5432/musuhi_db?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Musuhi AI API (journaling prompt)
# Local Node.js execution: http://localhost:8010
# Docker execution (next-app container): http://host.docker.internal:8010
MUSUHI_AI_API_URL="http://host.docker.internal:8010"
MUSUHI_AI_API_KEY=""

# Optional voice gift scheduler secret
VOICE_GIFT_CRON_SECRET=""

# アプリの公開 URL（メール内リンク生成に使用）
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Gmail SMTP (メール送信)
# Google アカウントで 2 段階認証を有効にし、アプリパスワードを発行して設定する
# 発行: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-account@gmail.com"
SMTP_PASS="your-app-password"
# メールアドレスのみ設定（表示名 "Musuhi｜Voice Gift" はコードで自動付与される）
# Cloudflare ルーティング経由のカスタムドメインアドレスを設定する場合はそのアドレスを指定
# Gmail の「別のアドレスとして送信」エイリアスへの事前登録が必要
SMTP_FROM="info@your-domain.com"

# 内部 API 呼び出し用シークレット（設定した場合 x-internal-secret ヘッダーが必須になる）
INTERNAL_API_SECRET=""
