// Prisma Schema File
// データベーススキーマの定義

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ユーザーモデル
model User {
  id            String   @id
  email         String   @unique
  name          String?
  displayName   String?
  avatarUrl     String?
  bio           String?
  location      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recordings              Recording[]
  sentGifts               Gift[]                  @relation("SentGifts")
  receivedGifts           Gift[]                  @relation("ReceivedGifts")
  yosegakiCreated         Yosegaki[]             @relation("YosegakiCreator")
  yosegakiContributions   YosegakiContribution[]
  boards                  Board[]
  comments                Comment[]
  likes                   Like[]
  connectionsInitiated    Connection[]           @relation("ConnectionInitiator")
  connectionsReceived     Connection[]           @relation("ConnectionReceiver")
}

// 録音データモデル
model Recording {
  id          String   @id @default(cuid())
  title       String
  description String?
  audioUrl    String
  duration    Int      // 秒単位
  emotions    String[] // AI分析による感情タグ
  images      String[] @default([]) // 添付画像のURL配列
  location    String?
  visibility  String   @default("private") // private, friends, public
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gifts                   Gift[]
  yosegakiContributions   YosegakiContribution[]

  @@index([userId])
  @@index([createdAt])
}

// ギフトモデル（1対1のボイスギフト）
model Gift {
  id             String    @id @default(cuid())
  title          String
  message        String?
  recordingId    String
  senderId       String
  recipientId    String?   // nullの場合はメール招待
  recipientEmail String?
  status         String    @default("sent") // sent, opened, expired
  isPublic       Boolean   @default(false)
  openedAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  sender    User      @relation("SentGifts", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User?     @relation("ReceivedGifts", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([recipientId])
  @@index([recipientEmail])
}

// 寄せ音声モデル（複数人からのメッセージ集）
model Yosegaki {
  id          String   @id @default(cuid())
  title       String
  description String?
  recipientName String
  recipientEmail String?
  creatorId   String
  dueDate     DateTime?
  status      String   @default("collecting") // collecting, completed, delivered
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator       User                   @relation("YosegakiCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  contributions YosegakiContribution[]

  @@index([creatorId])
  @@index([status])
}

// 寄せ音声への個別貢献
model YosegakiContribution {
  id          String   @id @default(cuid())
  yosegakiId  String
  recordingId String
  contributorId String
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  yosegaki    Yosegaki  @relation(fields: [yosegakiId], references: [id], onDelete: Cascade)
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  contributor User      @relation(fields: [contributorId], references: [id], onDelete: Cascade)

  @@unique([yosegakiId, contributorId])
  @@index([yosegakiId])
  @@index([contributorId])
}

// ボードモデル（コミュニティ投稿）
model Board {
  id          String   @id @default(cuid())
  title       String
  content     String?
  audioUrl    String?  // 音声付き投稿の場合
  duration    Int?     // 音声の長さ（秒）
  authorId    String
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]

  @@index([authorId])
  @@index([createdAt])
  @@index([isPublic])
}

// コメントモデル
model Comment {
  id        String   @id @default(cuid())
  content   String
  boardId   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board  Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([authorId])
}

// いいねモデル
model Like {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

// つながりモデル（フォロー/友達関係）
model Connection {
  id          String   @id @default(cuid())
  initiatorId String
  receiverId  String
  status      String   @default("pending") // pending, accepted, blocked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  initiator User @relation("ConnectionInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  receiver  User @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([initiatorId, receiverId])
  @@index([initiatorId])
  @@index([receiverId])
  @@index([status])
}
